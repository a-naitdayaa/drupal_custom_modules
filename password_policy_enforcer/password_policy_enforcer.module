<?php

declare(strict_types=1);

/**
 * implements hook_entity_base_field_info_alter().
 */
function password_policy_enforcer_entity_base_field_info_alter(&$fields, $entity_type) : void {

  if ($entity_type->id() === 'user') {
    $fields['pass']->addConstraint('UserPasswordPolicyConstraint');
  }

}
